---
layout: null
permalink: /search.json
---
{% capture items %}
{%- for post in site.posts -%}
  {%- assign is_hot = false -%}
  {%- if post.tags contains 'ai-hot' %}{% assign is_hot = true %}{% endif -%}
  {
    "type": {% if is_hot %}"ai-hot"{% else %}"note"{% endif %},
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": {{ post.date | date: '%Y-%m-%d' | jsonify }},
    "tags": {{ post.tags | jsonify }},
    "desc": {{ post.description | default: post.excerpt | strip_html | strip_newlines | truncate: 200 | jsonify }},
    "body": {{ post.content | strip_html | strip_newlines | truncate: 2600 | jsonify }}
  },
{%- endfor -%}
{%- for v in site.videos -%}
  {
    "type": "video",
    "title": {{ v.title | jsonify }},
    "url": {{ v.url | relative_url | jsonify }},
    "date": {{ v.date | date: '%Y-%m-%d' | jsonify }},
    "tags": ["视频", "AI 周报"],
    "desc": {{ v.lede | default: v.description | strip_html | strip_newlines | truncate: 200 | jsonify }},
    "body": {{ v.description | strip_html | strip_newlines | truncate: 800 | jsonify }}
  },
{%- endfor -%}
{%- for g in site.games -%}
  {
    "type": "game",
    "title": {{ g.title | jsonify }},
    "url": {{ g.play_url | relative_url | jsonify }},
    "date": {{ g.date | date: '%Y-%m-%d' | jsonify }},
    "tags": ["游戏"],
    "desc": {{ g.description | strip_html | strip_newlines | truncate: 200 | jsonify }},
    "body": ""
  },
{%- endfor -%}
{%- for s in site.data.showcases -%}
  {
    "type": "showcase",
    "title": {{ s.title | jsonify }},
    "url": {% if s.external %}{{ s.url | jsonify }}{% else %}{{ s.url | relative_url | jsonify }}{% endif %},
    "date": {{ s.date | jsonify }},
    "tags": {{ s.tags | jsonify }},
    "desc": {{ s.description | jsonify }},
    "body": ""
  },
{%- endfor -%}
{%- for a in site.data.apps -%}
  {
    "type": "app",
    "title": {{ a.title | jsonify }},
    "url": {{ a.url | jsonify }},
    "date": {{ a.date | jsonify }},
    "tags": {{ a.tags | jsonify }},
    "desc": {{ a.description | jsonify }},
    "body": ""
  },
{%- endfor -%}
{% endcapture %}
[{{ items | strip }} null]
